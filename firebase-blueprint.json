{
  "entities": {
    "Manufacturer": {
      "title": "Medical Equipment Manufacturer",
      "description": "Database of medical equipment manufacturers with logos and support info.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo_url": { "type": "string" },
        "website": { "type": "string" },
        "support_phone": { "type": "string" },
        "support_email": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Asset": {
      "title": "Medical Asset/Device",
      "description": "Comprehensive medical device record for CMMS tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "location": { "type": "string" },
        "department_id": { "type": "string" },
        "manufacturer_id": { "type": "string" },
        "manufacturer_name": { "type": "string" },
        "model": { "type": "string" },
        "serial_number": { "type": "string" },
        "purchase_date": { "type": "string", "format": "date" },
        "warranty_expiration": { "type": "string", "format": "date" },
        "asset_image_url": { "type": "string" },
        "pm_frequency": { "type": "string" },
        "next_pm_date": { "type": "string", "format": "date" },
        "imaging_modality": { "type": "string" }
      },
      "required": ["id", "name", "category", "status", "location"]
    },
    "Backup": {
      "title": "System Backup Record",
      "description": "Metadata regarding a system backup exported to Google Drive or internal storage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hospitalId": { "type": "string" },
        "fileId": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "size": { "type": "integer" },
        "status": { "type": "string" }
      },
      "required": ["id", "hospitalId", "fileId", "fileName", "createdAt", "size", "status"]
    },
    "DbChunk": {
      "title": "Database Binary Chunk",
      "description": "A base64 encoded chunk of the SQLite database file.",
      "type": "object",
      "properties": {
        "data": { "type": "string" },
        "totalChunks": { "type": "integer" },
        "timestamp": { "type": "integer" },
        "compressed": { "type": "boolean" }
      },
      "required": ["data", "totalChunks", "timestamp"]
    }
  },
  "firestore": {
    "/manufacturers/{mId}": {
      "schema": "Manufacturer",
      "description": "Global database of medical equipment manufacturers."
    },
    "/hospitals/{hospitalId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "Medical assets and devices tracked within specific hospital workspace."
    },
    "/hospitals/{hospitalId}/backups/{backupId}": {
      "schema": "Backup",
      "description": "Unified database log records of backups for each hospital isolate."
    },
    "/users/{userId}/backups/{backupId}": {
      "schema": "Backup",
      "description": "Personal backup records for specific users."
    },
    "/users/{userId}/dbBackup/{chunkId}": {
      "schema": "DbChunk",
      "description": "User-specific database backup chunks."
    },
    "/dbBackup/{chunkId}": {
      "schema": "DbChunk",
      "description": "Global system-wide database backup chunks for shared workspaces."
    },
    "/system/linkedAccounts": {
      "schema": "object",
      "description": "System-wide configuration for linked user accounts."
    }
  }
}
